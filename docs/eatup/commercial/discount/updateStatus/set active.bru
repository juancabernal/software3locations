meta {
  name: set active
  type: http
  seq: 2
}

patch {
  url: http://localhost:8080/comercial/api/v1/discounts/{{discountId}}/status
  body: json
  auth: inherit
}

body:json {
  {
    "status": true
  }
}

tests {
  test("Status code is 200", function() {
    expect(res.getStatus()).to.equal(200);
  });

  test("Status is true", function() {
    expect(res.getBody().status).to.equal(true);
  });
}

settings {
  encodeUrl: true
  timeout: 0
}