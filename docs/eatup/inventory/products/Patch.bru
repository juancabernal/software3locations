patch {
  url: http://localhost:8080/inventory/product/e8ae0e6c-ae33-4160-9b09-0fd78da75802
  body: json
  auth: inherit
}

body:json {
  {
    "name": "Tomate Rojo",
    "salePrice": 5500.000,
    "stock": 0
  }
}

tests {
  test("Patch exitoso", () => {
    expect(res.status).to.equal(200);
  });
  
  test("Precio actualizado", () => {
    expect(res.body.salePrice).to.equal(5300);
  });
}

