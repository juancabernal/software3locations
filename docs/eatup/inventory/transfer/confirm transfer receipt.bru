meta {
  name: confirm transfer receipt
  type: http
  seq: 8
}

patch {
  url: {{baseUrl}}/inventory/api/v1/transfers/{{transferId}}/confirm?sedeDestino={{sedeDestinoId}}
  body: none
  auth: inherit
}

vars:pre-request {
  baseUrl: http://localhost:8080
  sedeDestinoId: REPLACE_WITH_DESTINATION_LOCATION_ID
}

script:pre-request {
  const token = bru.getEnvVar("token") || bru.getVar("token");
  const transferId = bru.getVar("transferId");
  
  if (!token) {
    throw new Error("Missing variable 'token'. Run the login request first.");
  }
  
  if (!transferId) {
    throw new Error("Missing variable 'transferId'. Run 'create transfer' first.");
  }

  const sedeDestinoId = bru.getVar("sedeDestinoId");
  if (!sedeDestinoId || sedeDestinoId === "REPLACE_WITH_DESTINATION_LOCATION_ID") {
    throw new Error("Missing variable 'sedeDestinoId'. Set the destination location id before running this request.");
  }
}

script:post-response {
  const data = res.getBody();
  
  test("Status code is 200", function() {
    expect(res.getStatus()).to.equal(200);
  });
  
  test("Transfer is COMPLETADO", function() {
    expect(data.estado).to.equal("COMPLETADO");
  });
}

settings {
  encodeUrl: true
  timeout: 0
}
